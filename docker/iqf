from __future__ import annotations

import argparse
import os
import subprocess
import sys
from pathlib import Path

from iqf_path_mapper import (
    DEFAULT_DOCKERFILE,
    MODE_CHOICES,
    MODE_PATH_SPECS,
    MODEL_TYPES,
    PRECISION_CHOICES,
    RUNTIME_CHOICES,
    SUPPORTED_RUNTIME_PRECISION_COMBINATIONS,
    SUPPORTED_RUNTIME_PRECISION_ROWS,
    WrapperError,
    default_repo_root,
    docker_config_path,
    format_command,
    normalize_host_path,
    plan_build_command,
    plan_run_command,
    plan_shell_command,
    prompt_for_mode_paths,
    resolve_image_name,
    save_mode_paths,
)

COMMAND_CHOICES = {"build", "shell", "configure", "run"}
BUILD_DEFAULT_IMAGE = "iq-foundry:local"
ANSI_RED = "\033[31m"
ANSI_GREEN = "\033[32m"
ANSI_YELLOW = "\033[33m"
ANSI_CYAN = "\033[36m"
ANSI_WHITE = "\033[97m"
ANSI_RESET = "\033[0m"


# configure runs on the host before any container or model-specific Python dependencies are
# available, so the wrapper keeps its own tiny console helpers instead of importing cli.py.
def color_text(text: str, color: str) -> str:
    return f"{color}{text}{ANSI_RESET}"


def print_error(message: str) -> None:
    print(color_text(message, ANSI_RED))


def print_warning(message: str) -> None:
    print(color_text(message, ANSI_YELLOW))


def print_info(message: str) -> None:
    print(color_text(message, ANSI_CYAN))


def print_success(message: str) -> None:
    print(color_text(message, ANSI_GREEN))


def print_boxed_summary(lines: list[str]) -> None:
    width = max(len(line) for line in lines)
    border = "+" + "-" * (width + 2) + "+"
    print(color_text(border, ANSI_GREEN))
    for line in lines:
        print(color_text(f"| {line.ljust(width)} |", ANSI_WHITE))
    print(color_text(border, ANSI_GREEN))


def next_run_command(mode: str, model_type: str, runtime: str, precision: str) -> str:
    command = (
        f"./docker/iqf run {mode} --type {model_type} "
        f"--runtime {runtime} --precision {precision}"
    )
    # Test configure is primarily used for on-device runs, so the next-step hint includes the
    # common ADB flag while keeping the saved path contract unchanged.
    if mode == "test":
        command += " --adb"
    return command


def configure_ready_box_lines(
    mode: str, model_type: str, runtime: str, precision: str
) -> list[str]:
    return [
        f"{mode} mode is ready for execution!",
        f"Run: {next_run_command(mode, model_type, runtime, precision)}",
    ]


